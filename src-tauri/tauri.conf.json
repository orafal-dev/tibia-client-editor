{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Tibia Client Editor",
  "version": "0.1.1",
  "identifier": "com.orafal-dev.tibia-client-editor",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev -- --port 1420",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Tibia Client Editor",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdEQ0M3OTlENDA1M0Y1NDAKUldSQTlWTkFuWG5NZlZwQ2pwS0FPZ252RzZyTEhCUjlBOHI5ckY0VWJndEJPaTlpYm5YQlFrQm0K",
      "endpoints": [
        "https://github.com/orafal-dev/tibia-client-editor/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
